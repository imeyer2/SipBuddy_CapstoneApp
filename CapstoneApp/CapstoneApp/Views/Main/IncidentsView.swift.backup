import SwiftUI

struct IncidentsView: View {
    @EnvironmentObject var ble: BLEManager
    @EnvironmentObject var store: IncidentStore

             HStack {
            HStack {
                ShareButton(images: images, complete: incident?.isComplete ?? false, id: incidentID)
                Spacer()
